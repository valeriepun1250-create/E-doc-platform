{
  "form": {
    "specialty": "NS",
    "title": "NS Initial Assessment",
    "description": "Neurosurgery initial assessment.",
    "schema": {
      "sections": [
        {
          "title": "Vital, Social History, Home environment & premorbid ADL",
          "questions": [
            {
              "id": "vitals",
              "label": "Vital signs",
              "hideLabel": true,
              "type": "composite",
              "width": "full",
              "parts": [
                {
                  "id": "bp_sys",
                  "label": "BP",
                  "placeholder": "120",
                  "suffix": "/"
                },
                {
                  "id": "bp_dia",
                  "label": "",
                  "placeholder": "80",
                  "suffix": " mmHg"
                },
                {
                  "id": "p",
                  "label": "Pulse",
                  "placeholder": "78",
                  "suffix": "/min"
                },
                {
                  "id": "spo2",
                  "label": "SpO2",
                  "placeholder": "98",
                  "suffix": "%"
                },
                {
                  "id": "o2",
                  "label": "",
                  "placeholder": "Room Air / L O2",
                  "wide": true
                }
              ],
              "joinWith": "  ",
              "reportTemplate": "Vital signs: BP {bp_sys}/{bp_dia} mmHg  P {p}/min  SpO2 {spo2}% ({o2})"
            },
            {
              "id": "_h_social",
              "label": "Social History, Home environment & premorbid ADL",
              "type": "heading"
            },
            {
              "id": "lives_with",
              "label": "Lives with",
              "type": "checkbox",
              "width": "full",
              "options": [
                "Live alone",
                "Spouse",
                "Child(ren)",
                "Parent(s)",
                "Sibling(s)",
                "Domestic helper",
                "Day time alone",
                "Night time alone",
                "OAHR",
                "Hostel"
              ],
              "allowOther": true,
              "allowComment": true,
              "commentLabel": "Main carer / details"
            },
            {
              "id": "home_access",
              "label": "Home access",
              "type": "multiple_choice",
              "width": "half",
              "options": [
                "Direct lift-landing",
                {
                  "value": "Non-direct lift-landing",
                  "subOptions": [],
                  "subAllowOther": true
                },
                {
                  "value": "No lift",
                  "subOptions": [],
                  "subAllowOther": true
                }
              ],
              "allowComment": true,
              "commentLabel": "Floor / stairs detail"
            },
            {
              "id": "bathing_setup",
              "label": "Bathing setup",
              "type": "checkbox",
              "width": "half",
              "options": [
                "Tub",
                "Shower",
                "Hot water system"
              ],
              "allowOther": true
            },
            {
              "id": "bath_method",
              "label": "Bath by",
              "type": "multiple_choice",
              "width": "half",
              "options": [
                "Stand",
                "Squat",
                {
                  "value": "Sit on",
                  "subOptions": [
                    "Bath chair",
                    "Tub board",
                    "Shower stool"
                  ],
                  "subAllowOther": true
                },
                "Bedbath"
              ]
            },
            {
              "id": "premorbid_badl",
              "label": "Premorbid BADL",
              "type": "multiple_choice",
              "width": "half",
              "options": [
                "Independent",
                "Supervision",
                "Mild Assistance",
                "Moderate Assistance",
                "Maximal Assistance",
                "Dependent"
              ],
              "reportTemplate": "Premorbid BADL: {answer}."
            },
            {
              "id": "premorbid_iadl",
              "label": "Premorbid IADL",
              "type": "multiple_choice",
              "width": "half",
              "options": [
                "Independent",
                "Supervision",
                "Mild Assistance",
                "Moderate Assistance",
                "Maximal Assistance",
                "Dependent"
              ],
              "reportTemplate": "Premorbid IADL: {answer}."
            },
            {
              "id": "premorbid_walk",
              "label": "Premorbid walking status",
              "type": "multiple_choice",
              "width": "half",
              "options": [
                "Walk unaided",
                {
                  "value": "With aid",
                  "subOptions": [
                    "Stick",
                    "Quad stick",
                    "Frame",
                    "Rollator",
                    "Trolley"
                  ],
                  "subAllowOther": true
                },
                "Chair bound",
                "Bed bound"
              ],
              "reportTemplate": "Premorbid mobility: {answer}."
            },
            {
              "id": "outdoor",
              "label": "Outdoor mobility",
              "type": "short_text",
              "width": "half",
              "hint": "e.g. independent in community / accompanied / housebound"
            },
            {
              "id": "occupation",
              "label": "Occupation",
              "type": "multiple_choice",
              "width": "half",
              "options": [
                "Retired"
              ],
              "allowOther": true,
              "otherPlaceholder": "occupation"
            },
            {
              "id": "financial",
              "label": "Financial support",
              "type": "checkbox",
              "width": "full",
              "options": [
                "Family support / saving",
                "Public allowance",
                "Comprehensive Social Security Assistance",
                "Disability Allowance",
                "Old Age Allowance",
                "Old Age Living Allowance"
              ],
              "allowOther": true
            },
            {
              "id": "social_service",
              "label": "Social service",
              "type": "checkbox",
              "width": "full",
              "options": [
                "Nil",
                {
                  "value": "Day Care centre",
                  "detail": true,
                  "detailPlaceholder": "name / frequency"
                },
                {
                  "value": "Elderly Centre",
                  "detail": true,
                  "detailPlaceholder": "name / frequency"
                },
                {
                  "value": "Respite Services",
                  "detail": true,
                  "detailPlaceholder": "name / frequency"
                },
                {
                  "value": "Home Help — Meal on wheels",
                  "detail": true,
                  "detailPlaceholder": "frequency"
                },
                {
                  "value": "Home Help — Personal care",
                  "detail": true,
                  "detailPlaceholder": "frequency"
                },
                {
                  "value": "Home Help — Household",
                  "detail": true,
                  "detailPlaceholder": "frequency"
                },
                {
                  "value": "Home Help — Escort",
                  "detail": true,
                  "detailPlaceholder": "frequency"
                }
              ],
              "allowOther": true
            },
            {
              "id": "assistive_devices",
              "label": "Assistive devices",
              "type": "checkbox",
              "width": "full",
              "options": [
                "Nil",
                "Safety alarm",
                "Commode",
                "Handrail",
                {
                  "value": "Walking aids",
                  "subOptions": [
                    "Stick",
                    "Quad stick",
                    "Frame",
                    "Rollator"
                  ],
                  "subAllowOther": true
                },
                "Wheelchair"
              ],
              "allowOther": true
            }
          ],
          "reportTitle": "A. Common Assessment"
        },
        {
          "title": "Mental & Cognitive Function",
          "questions": [
            {
              "id": "gcs",
              "label": "GCS",
              "type": "composite",
              "width": "half",
              "parts": [
                {
                  "id": "e",
                  "label": "E",
                  "placeholder": "1-4"
                },
                {
                  "id": "v",
                  "label": "V",
                  "placeholder": "1-5"
                },
                {
                  "id": "m",
                  "label": "M",
                  "placeholder": "1-6"
                }
              ],
              "joinWith": " ",
              "reportTemplate": "GCS: {answer}"
            },
            {
              "id": "mental_state",
              "label": "Mental state",
              "type": "multiple_choice",
              "width": "half",
              "options": [
                "Alert",
                "Confused",
                "Drowsy",
                "Stupor"
              ],
              "allowComment": true
            },
            {
              "id": "follow_cmd",
              "label": "Follow command",
              "type": "multiple_choice",
              "width": "half",
              "options": [
                "1 step",
                "2 steps",
                "3 steps",
                "Not follow command"
              ],
              "reportTemplate": "Follow command: {answer}."
            },
            {
              "id": "orientation",
              "label": "Orientated to",
              "type": "checkbox",
              "width": "half",
              "options": [
                "Name",
                "Age",
                "Time",
                "Place",
                "Person"
              ]
            },
            {
              "id": "cog_status",
              "label": "Cognitive assessment status",
              "type": "multiple_choice",
              "width": "full",
              "options": [
                "Performed",
                "Failed to assess due to poor GCS",
                "Declined",
                "Not applicable"
              ]
            },
            {
              "id": "amt",
              "label": "Abbreviated Mental Test (AMT)",
              "type": "sub_score",
              "mode": "options",
              "totalMax": 10,
              "removable": true,
              "width": "full",
              "hint": "Cut-off <6 indicates further evaluation for possible cognitive impairment.",
              "items": [
                {
                  "id": "age",
                  "label": "Age",
                  "options": [
                    0,
                    1
                  ]
                },
                {
                  "id": "time",
                  "label": "Time",
                  "options": [
                    0,
                    1
                  ]
                },
                {
                  "id": "addr",
                  "label": "Address for recall",
                  "options": [
                    0,
                    1
                  ]
                },
                {
                  "id": "year",
                  "label": "Current year",
                  "options": [
                    0,
                    1
                  ]
                },
                {
                  "id": "place",
                  "label": "Place",
                  "options": [
                    0,
                    1
                  ]
                },
                {
                  "id": "recog",
                  "label": "Recognition of two persons",
                  "options": [
                    0,
                    1
                  ]
                },
                {
                  "id": "dob",
                  "label": "Date of birth",
                  "options": [
                    0,
                    1
                  ]
                },
                {
                  "id": "festival",
                  "label": "Date of mid-Autumn festival",
                  "options": [
                    0,
                    1
                  ]
                },
                {
                  "id": "leader",
                  "label": "Name of present Governor / leader",
                  "options": [
                    0,
                    1
                  ]
                },
                {
                  "id": "count_back",
                  "label": "Count from 20 to 1 backwards",
                  "options": [
                    0,
                    1
                  ]
                }
              ],
              "reportTemplate": "AMT: Total score: {answer} (Cut-off <6 indicates further evaluation for possibility of cognitive impairment)",
              "showIf": {
                "questionId": "cog_status",
                "equals": "Performed"
              }
            },
            {
              "id": "cdt",
              "label": "Clock Drawing Test (CDT)",
              "type": "rating",
              "min": 0,
              "max": 10,
              "removable": true,
              "width": "full",
              "hint": "Cut-off 4. Sensitivity 83% / specificity 79% for dementia screening. Lower score indicates lower cognitive function.",
              "reportTemplate": "Clock Drawing Test (CDT): {answer} (Cut-off 4)",
              "showIf": {
                "questionId": "cog_status",
                "equals": "Performed"
              }
            },
            {
              "id": "moca",
              "label": "HK-Montreal Cognitive Assessment (MoCA)",
              "type": "sub_score",
              "mode": "max",
              "totalMax": 30,
              "removable": true,
              "width": "full",
              "headerInputs": [
                {
                  "id": "moca_education",
                  "label": "Education",
                  "placeholder": "e.g. F.6",
                  "reportTemplate": "[Educational level: {answer}]"
                }
              ],
              "items": [
                {
                  "id": "visuospatial",
                  "label": "Visuospatial / Executive",
                  "max": 5
                },
                {
                  "id": "naming",
                  "label": "Naming",
                  "max": 3
                },
                {
                  "id": "attention",
                  "label": "Attention",
                  "max": 6
                },
                {
                  "id": "language",
                  "label": "Language",
                  "max": 3
                },
                {
                  "id": "abstraction",
                  "label": "Abstraction",
                  "max": 2
                },
                {
                  "id": "recall",
                  "label": "Delayed Recall",
                  "max": 5
                },
                {
                  "id": "orientation",
                  "label": "Orientation",
                  "max": 6
                }
              ],
              "reportTemplate": "MoCA: Total score: {answer}",
              "showIf": {
                "questionId": "cog_status",
                "equals": "Performed"
              }
            },
            {
              "id": "moca_band",
              "label": "MoCA percentile",
              "type": "multiple_choice",
              "mergeUp": true,
              "width": "full",
              "options": [
                ">16th percentile",
                "≤16th percentile: DSM-5 mild NCD",
                "≤7th percentile: Petersen MCI",
                "≤2nd percentile: DSM-5 major NCD"
              ],
              "reportTemplate": "Interpretation: {answer}.",
              "showIf": {
                "questionId": "cog_status",
                "equals": "Performed"
              }
            },
            {
              "id": "cog_impression",
              "label": "Cognitive impression",
              "type": "long_text",
              "width": "half",
              "showIf": {
                "questionId": "cog_status",
                "equals": "Performed"
              }
            },
            {
              "id": "speech",
              "label": "Speech",
              "type": "checkbox",
              "width": "full",
              "options": [
                "Normal",
                "Expressive dysphasia",
                "Receptive dysphasia",
                "Dysarthria"
              ],
              "allowOther": true
            }
          ],
          "reportTitle": "C. Mental Function"
        },
        {
          "title": "Physical Assessment",
          "questions": [
            {
              "id": "complaint",
              "label": "Major complaint / others",
              "type": "long_text",
              "width": "full"
            },
            {
              "id": "power",
              "label": "Power",
              "type": "composite",
              "layout": "grid-2x2",
              "width": "half",
              "rowHeaders": [
                "Upper",
                "Lower"
              ],
              "colHeaders": [
                "Right",
                "Left"
              ],
              "parts": [
                {
                  "id": "rul",
                  "placeholder": "5"
                },
                {
                  "id": "lul",
                  "placeholder": "5"
                },
                {
                  "id": "rll",
                  "placeholder": "5"
                },
                {
                  "id": "lll",
                  "placeholder": "5"
                }
              ],
              "reportTemplate": "Power:\n{rul} | {lul}\n{rll} | {lll}"
            },
            {
              "id": "tone",
              "label": "Tone",
              "type": "short_text",
              "width": "half",
              "hint": "e.g. normal / increased on left side"
            },
            {
              "id": "coordination",
              "label": "Coordination",
              "type": "short_text",
              "width": "half",
              "hint": "e.g. NAD / dysmetria L UL"
            },
            {
              "id": "balance_sit",
              "label": "Balance — Sitting",
              "type": "checkbox",
              "width": "half",
              "options": [
                "Good",
                "Fair",
                "Poor"
              ],
              "combineAdjacent": true
            },
            {
              "id": "balance_stand",
              "label": "Balance — Standing",
              "type": "checkbox",
              "width": "half",
              "options": [
                "Good",
                "Fair",
                "Poor"
              ],
              "combineAdjacent": true
            },
            {
              "id": "transfer_lie_sit",
              "label": "Transfer — Lie to sit",
              "type": "multiple_choice",
              "width": "half",
              "options": [
                "Independent",
                "Supervision",
                "Mild Assistance",
                "Moderate Assistance",
                "Maximal Assistance",
                "Dependent",
                {
                  "value": "Aid",
                  "subOptions": [
                    "Stick",
                    "Quad stick",
                    "Frame",
                    "Rollator",
                    "Walking belt",
                    "Hoist"
                  ],
                  "subAllowOther": true
                }
              ]
            },
            {
              "id": "transfer_sit_stand",
              "label": "Transfer — Sit to stand",
              "type": "multiple_choice",
              "width": "half",
              "options": [
                "Independent",
                "Supervision",
                "Mild Assistance",
                "Moderate Assistance",
                "Maximal Assistance",
                "Dependent",
                {
                  "value": "Aid",
                  "subOptions": [
                    "Stick",
                    "Quad stick",
                    "Frame",
                    "Rollator",
                    "Walking belt",
                    "Hoist"
                  ],
                  "subAllowOther": true
                }
              ]
            },
            {
              "id": "ambulation",
              "label": "Ambulation",
              "type": "multiple_choice",
              "width": "half",
              "options": [
                "Independent",
                "Supervision",
                "Mild Assistance",
                "Moderate Assistance",
                "Maximal Assistance",
                "Dependent",
                {
                  "value": "Aid",
                  "subOptions": [
                    "Stick",
                    "Quad stick",
                    "Frame",
                    "Rollator",
                    "Walking belt"
                  ],
                  "subAllowOther": true
                }
              ]
            },
            {
              "id": "vision",
              "label": "Vision",
              "type": "multiple_choice",
              "width": "half",
              "options": [
                "Normal"
              ],
              "allowOther": true,
              "otherPlaceholder": "describe deficit"
            },
            {
              "id": "hearing",
              "label": "Hearing",
              "type": "multiple_choice",
              "width": "half",
              "options": [
                "Normal",
                {
                  "value": "Impaired",
                  "subOptions": [
                    "Left",
                    "Right",
                    "Bilateral"
                  ]
                },
                "Deaf"
              ]
            },
            {
              "id": "fthue",
              "label": "Hand function — FTHUE",
              "type": "rating",
              "min": 0,
              "max": 7,
              "width": "half",
              "hint": "Functional Test for the Hemiplegic Upper Extremity",
              "reportTemplate": "Hand function (FTHUE): {answer}"
            },
            {
              "id": "sensation",
              "label": "Sensation / Proprioception",
              "type": "multiple_choice",
              "width": "half",
              "options": [
                "NAD"
              ],
              "allowOther": true,
              "otherPlaceholder": "describe deficit"
            },
            {
              "id": "spinal_region",
              "label": "Spinal assessment",
              "type": "checkbox",
              "width": "full",
              "hint": "Select one or both to expand spinal assessment tools.",
              "options": [
                "Spinal_Cervical",
                "Spinal_Thoraco-Lumba"
              ]
            },
            {
              "id": "asia_chart",
              "label": "Sensory and Motor Chart (ASIA)",
              "type": "asia_chart",
              "width": "full",
              "motorLevels": [
                "C5",
                "C6",
                "C7",
                "C8",
                "T1",
                "L2",
                "L3",
                "L4",
                "L5",
                "S1"
              ],
              "reportTemplate": "{answer}",
              "showIf": {
                "questionId": "spinal_region",
                "anyOf": [
                  "Spinal_Cervical",
                  "Spinal_Thoraco-Lumba"
                ]
              }
            },
            {
              "type": "heading",
              "label": "Disease-specific Assessment — Spinal_Cervical",
              "showIf": {
                "questionId": "spinal_region",
                "equals": "Spinal_Cervical"
              }
            },
            {
              "id": "cervical_ndi",
              "label": "Neck Disability Index",
              "type": "sub_score",
              "mode": "options",
              "totalMax": 50,
              "width": "full",
              "customReport": "spinal_cervical_disease",
              "breakdownItemsPerLine": 5,
              "breakdownSep": "   ",
              "showIf": {
                "questionId": "spinal_region",
                "equals": "Spinal_Cervical"
              },
              "items": [
                {
                  "id": "pain_intensity",
                  "label": "Pain intensity",
                  "options": [
                    0,
                    1,
                    2,
                    3,
                    4,
                    5
                  ]
                },
                {
                  "id": "personal_care",
                  "label": "Personal care",
                  "options": [
                    0,
                    1,
                    2,
                    3,
                    4,
                    5
                  ]
                },
                {
                  "id": "lifting",
                  "label": "Lifting",
                  "options": [
                    0,
                    1,
                    2,
                    3,
                    4,
                    5
                  ]
                },
                {
                  "id": "reading",
                  "label": "Reading",
                  "options": [
                    0,
                    1,
                    2,
                    3,
                    4,
                    5
                  ]
                },
                {
                  "id": "headaches",
                  "label": "Headaches",
                  "options": [
                    0,
                    1,
                    2,
                    3,
                    4,
                    5
                  ]
                },
                {
                  "id": "concentration",
                  "label": "Concentration",
                  "options": [
                    0,
                    1,
                    2,
                    3,
                    4,
                    5
                  ]
                },
                {
                  "id": "work",
                  "label": "Work",
                  "options": [
                    0,
                    1,
                    2,
                    3,
                    4,
                    5
                  ]
                },
                {
                  "id": "driving",
                  "label": "Driving",
                  "options": [
                    0,
                    1,
                    2,
                    3,
                    4,
                    5
                  ]
                },
                {
                  "id": "sleeping",
                  "label": "Sleeping",
                  "options": [
                    0,
                    1,
                    2,
                    3,
                    4,
                    5
                  ]
                },
                {
                  "id": "recreation",
                  "label": "Recreation",
                  "options": [
                    0,
                    1,
                    2,
                    3,
                    4,
                    5
                  ]
                }
              ]
            },
            {
              "id": "cervical_pain_vas",
              "label": "Pain assessment — VAS",
              "type": "rating",
              "min": 0,
              "max": 10,
              "width": "full",
              "hideInReport": true,
              "showIf": {
                "questionId": "spinal_region",
                "equals": "Spinal_Cervical"
              }
            },
            {
              "id": "cervical_joa",
              "label": "JOA",
              "type": "sub_score",
              "mode": "max",
              "totalMax": 17,
              "width": "full",
              "hideInReport": true,
              "breakdownItemsPerLine": 3,
              "breakdownSep": "   ",
              "showIf": {
                "questionId": "spinal_region",
                "equals": "Spinal_Cervical"
              },
              "items": [
                {
                  "id": "motor_function",
                  "label": "Motor Function",
                  "max": 8
                },
                {
                  "id": "sensory_function",
                  "label": "Sensory Function",
                  "max": 6
                },
                {
                  "id": "bladder_function",
                  "label": "Bladder Function",
                  "max": 3
                }
              ]
            },
            {
              "id": "spinal_cervical_other",
              "label": "Spinal_Cervical other assessment",
              "type": "long_text",
              "width": "full",
              "placeholder": "e.g. collar tolerance, upper limb function, respiratory status, pressure area, precautions",
              "reportTemplate": "Spinal_Cervical other assessment: {answer}",
              "showIf": {
                "questionId": "spinal_region",
                "equals": "Spinal_Cervical"
              }
            },
            {
              "id": "spinal_thoraco_lumba_other",
              "label": "Spinal_Thoraco-Lumba other assessment",
              "type": "long_text",
              "width": "full",
              "placeholder": "e.g. TLSO tolerance, lower limb function, sitting balance, transfer, bladder/bowel, precautions",
              "reportTemplate": "Spinal_Thoraco-Lumba other assessment: {answer}",
              "showIf": {
                "questionId": "spinal_region",
                "equals": "Spinal_Thoraco-Lumba"
              }
            }
          ],
          "reportTitle": "D. Physical Assessment"
        },
        {
          "title": "Functional Assessment (Modified Barthel Index)",
          "questions": [
            {
