                ]
              }
            ]
          }
        ],
        "reportTitle": "Functional Assessment"
      },
      {
        "title": "Cognitive Assessment",
        "questions": [
          {
            "id": "moca",
            "label": "HK-Montreal Cognitive Assessment (MoCA)",
            "type": "sub_score",
            "mode": "max",
            "totalMax": 30,
            "width": "full",
            "breakdownItemsPerLine": 4,
            "breakdownSep": "   ",
            "customReport": "moca_full",
            "headerInputs": [
              {
                "id": "moca_age_cluster",
                "label": "Age",
                "type": "select",
                "placeholder": "Select age",
                "options": [
                  "65-69",
                  "70-79",
                  "≥80"
                ]
              },
              {
                "id": "moca_education",
                "label": "Education",
                "type": "number",
                "inputType": "number",
                "placeholder": "Years",
                "min": 0,
                "step": 1
              }
            ],
            "items": [
              {
                "id": "executive_function",
                "label": "Executive Function",
                "max": 5
              },
              {
                "id": "naming",
                "label": "Naming",
                "max": 3
              },
              {
                "id": "attention",
                "label": "Attention",
                "max": 6
              },
              {
                "id": "language",
                "label": "Language",
                "max": 3
              },
              {
                "id": "abstraction",
                "label": "Abstraction",
                "max": 2
              },
              {
                "id": "delayed_recall",
                "label": "Delayed Recall",
                "max": 5
              },
              {
                "id": "orientation",
                "label": "Orientation",
                "max": 6
              }
            ]
