{
  "specialty": "NS",
  "title": "NS Initial Assessment",
  "description": "Neurosurgery initial assessment.",
  "schema": {
    "sections": [
      {
        "title": "Vital signs and Premorbid ADL",
        "questions": [
          {
            "type": "heading",
            "label": "Vital signs"
          },
          {
            "id": "vitals",
            "label": "Vital signs",
            "hideLabel": true,
            "type": "composite",
            "width": "full",
            "parts": [
              {
                "id": "bp_sys",
                "label": "BP",
                "placeholder": "120",
                "suffix": "/"
              },
              {
                "id": "bp_dia",
                "label": "",
                "placeholder": "80",
                "suffix": " mmHg"
              },
              {
                "id": "p",
                "label": "Pulse",
                "placeholder": "78",
                "suffix": "/min"
              },
              {
                "id": "spo2",
                "label": "SpO2",
                "placeholder": "98",
                "suffix": "%"
              },
              {
                "id": "o2",
                "label": "",
                "placeholder": "Room Air / L O2",
                "wide": true
              }
            ],
            "joinWith": "  ",
            "reportTemplate": "Vital signs: BP {bp_sys}/{bp_dia} mmHg, Pulse {p}/minute, SpO2 {spo2}%."
          },
          {
            "type": "heading",
            "label": "Premorbid ADL",
            "headerTriggerQuestionId": "social_limited"
          },
          {
            "id": "social_limited",
            "label": "Limited information",
            "hideLabel": true,
            "type": "checkbox",
            "width": "full",
            "tickStyle": true,
            "options": [
              "Limited information from patient"
            ],
            "reportTemplate": "Premorbid ADL: limited information from patient."
          },
          {
            "id": "premorbid_badl",
            "label": "Premorbid Basic ADL",
            "type": "checkbox",
            "width": "half",
            "options": [
              "Independent",
              {
                "value": "Independent up to",
                "detail": true,
                "detailPlaceholder": "details",
                "detailJoiner": " "
              },
              {
                "value": "Supervision in",
                "detail": true,
                "detailPlaceholder": "details",
                "detailJoiner": " "
              },
              {
                "value": "Assist in",
                "detail": true,
                "detailPlaceholder": "details",
                "detailJoiner": " "
              },
              "Dependent"
            ],
            "customReport": "premorbid_adl",
            "showIf": {
              "questionId": "social_limited",
              "notEquals": "Limited information from patient"
            }
          },
          {
            "id": "indoor_walk",
            "label": "Indoor mobility / Walk",
            "type": "multiple_choice",
            "width": "full",
            "options": [
              "Independent",
              "Supervision",
              "Assisted",
              "Dependent"
            ],
            "hideInReport": true,
            "showIf": {
              "questionId": "social_limited",
              "notEquals": "Limited information from patient"
            },
            "allowComment": true,
            "commentLabel": "Remark",
            "commentSingleLine": true,
            "commentPlaceholder": "add detail"
          },
          {
            "id": "indoor_aid",
            "label": "Indoor aid",
            "type": "multiple_choice",
            "width": "full",
            "mergeUp": true,
            "options": [
              "Unaided",
              "Stick",
              "Quadripod",
              "Frame",
              "Rollator",
              "Trolley",
              "Chairbound",
              "Bedbound"
            ],
            "allowOther": true,
            "otherPlaceholder": "specify",
            "hideInReport": true,
            "showIf": {
              "questionId": "social_limited",
              "notEquals": "Limited information from patient"
            }
          },
          {
            "id": "outdoor_walk",
            "label": "Outdoor mobility / Walk",
            "type": "multiple_choice",
            "width": "full",
            "options": [
              "Independent",
              "Supervision",
              "Assisted",
              "Dependent"
            ],
            "hideInReport": true,
            "showIf": {
              "questionId": "social_limited",
              "notEquals": "Limited information from patient"
            },
            "allowComment": true,
            "commentLabel": "Remark",
            "commentSingleLine": true,
            "commentPlaceholder": "add detail"
          },
          {
            "id": "outdoor_aid",
            "label": "Outdoor aid",
            "type": "multiple_choice",
            "width": "full",
            "mergeUp": true,
            "options": [
              "Unaided",
              "Stick",
              "Quadripod",
              "Frame",
              "Rollator",
              "Trolley",
              "Wheelchair"
            ],
            "allowOther": true,
            "otherPlaceholder": "specify",
            "hideInReport": true,
            "showIf": {
              "questionId": "social_limited",
              "notEquals": "Limited information from patient"
            }
          },
          {
            "id": "premorbid_iadl",
            "label": "Premorbid IADL",
            "type": "checkbox",
            "width": "half",
            "options": [
              "Independent",
              {
                "value": "Independent up to",
                "detail": true,
                "detailPlaceholder": "details",
                "detailJoiner": " "
              },
              {
                "value": "Supervision in",
                "detail": true,
                "detailPlaceholder": "details",
                "detailJoiner": " "
              },
              {
                "value": "Assist in",
                "detail": true,
                "detailPlaceholder": "details",
                "detailJoiner": " "
              },
              "Dependent"
            ],
            "hideInReport": true,
            "showIf": {
              "questionId": "social_limited",
              "notEquals": "Limited information from patient"
            }
          },
          {
            "id": "occupation",
            "label": "Occupation",
            "type": "multiple_choice",
            "width": "half",
            "options": [
              "Retired"
            ],
            "allowOther": true,
            "otherPlaceholder": "occupation",
            "hideInReport": true,
            "showIf": {
              "questionId": "social_limited",
              "notEquals": "Limited information from patient"
            }
          }
        ],
        "reportTitle": "A. Vital signs and Premorbid ADL",
        "hideReportTitle": true
      },
      {
        "title": "Social History and Home Environment",
        "hideQuestionsIf": {
          "questionId": "social_limited_sh",
          "equals": "Limited information from patient"
        },
        "questions": [
          {
            "id": "social_limited_sh",
            "label": "Limited information",
            "hideLabel": true,
            "type": "checkbox",
            "width": "full",
            "tickStyle": true,
            "options": [
              "Limited information from patient"
            ],
            "reportTemplate": "Limited information from patient."
          },
          {
            "id": "lives_with",
            "label": "Lives with",
            "type": "checkbox",
            "width": "full",
            "options": [
              {
                "value": "Live with",
                "detail": true,
                "detailPlaceholder": "spouse / child / domestic helper"
              },
              "Live alone",
              "OAHR",
              "Hostel",
              "Day time alone",
              "Night time alone"
            ],
            "allowOther": true,
            "allowComment": true,
            "commentLabel": "Main carer / details",
            "customReport": "social_lives_home"
          },
          {
            "id": "home_access",
            "label": "Home access",
            "type": "multiple_choice",
            "width": "half",
            "options": [
              "Direct lift-landing",
              {
                "value": "Non-direct lift-landing",
                "subOptions": [],
                "subAllowOther": true
              },
              {
                "value": "No lift",
                "subOptions": [],
                "subAllowOther": true
              }
            ],
            "allowComment": true,
            "commentLabel": "Floor / stairs detail",
            "hideInReport": true
          },
          {
            "id": "bathing_setup",
            "label": "Bathing setup",
            "type": "checkbox",
            "width": "full",
            "options": [
              "Tub",
              "Shower",
              "Hot water system"
            ],
            "allowOther": true,
            "customReport": "bathing_combo"
          },
          {
            "id": "bath_method",
            "label": "Bath by",
            "type": "multiple_choice",
            "width": "full",
            "mergeUp": true,
            "options": [
              "Stand",
              "Squat",
              {
                "value": "Sit on",
                "subOptions": [
                  "Shower chair",
                  "Tub board",
                  "Shower stool"
                ],
                "subAllowOther": true
              },
              "Bedbath"
            ],
            "hideInReport": true
          },
          {
            "id": "financial",
            "label": "Financial support",
            "type": "checkbox",
            "width": "full",
            "options": [
              "Family support / saving",
              "Public allowance",
              "Comprehensive Social Security Assistance",
              "Disability Allowance",
              "Old Age Allowance",
              "Old Age Living Allowance"
            ],
            "allowOther": true
          },
          {
            "id": "social_service",
            "label": "Social service",
            "type": "checkbox",
            "width": "full",
            "options": [
              "Nil",
              {
                "value": "Day Care centre",
                "detail": true,
                "detailPlaceholder": "name / frequency",
                "detailJoiner": " (",
                "detailSuffix": ")"
              },
              {
                "value": "Elderly Centre",
                "detail": true,
                "detailPlaceholder": "name / frequency",
                "detailJoiner": " (",
                "detailSuffix": ")"
              },
              {
                "value": "Respite Services",
                "detail": true,
                "detailPlaceholder": "name / frequency",
                "detailJoiner": " (",
                "detailSuffix": ")"
              },
              {
                "value": "Home Help Service",
                "subOptions": [
                  {
                    "value": "Meal on wheels",
                    "detail": true,
                    "detailPlaceholder": "frequency"
                  },
                  {
                    "value": "Personal care",
                    "detail": true,
                    "detailPlaceholder": "frequency"
                  },
                  {
                    "value": "Household",
                    "detail": true,
                    "detailPlaceholder": "frequency"
                  },
                  {
                    "value": "Escort",
                    "detail": true,
                    "detailPlaceholder": "frequency"
                  }
                ],
                "subAllowOther": true
              }
            ],
            "allowOther": true
          },
          {
            "id": "assistive_devices",
            "label": "Assistive devices",
            "type": "checkbox",
            "width": "full",
            "options": [
              "Nil",
              "Safety alarm",
              "Commode",
              "Handrail",
              {
                "value": "Walking aids",
                "subOptions": [
                  "Stick",
                  "Quadripod",
                  "Frame",
                  "Rollator"
                ],
                "subAllowOther": true
              },
              "Wheelchair"
            ],
            "allowOther": true
          }
        ],
        "reportTitle": "C. Social History and Home Environment"
      },
      {
        "title": "Mental & Cognitive Function",
        "questions": [
          {
            "id": "gcs",
            "label": "GCS",
            "type": "composite",
            "width": "half",
            "parts": [
              {
                "id": "e",
                "label": "E",
                "placeholder": "1-4"
              },
              {
                "id": "v",
                "label": "V",
                "placeholder": "1-5"
              },
              {
                "id": "m",
                "label": "M",
                "placeholder": "1-6"
              }
            ],
            "joinWith": " ",
            "reportTemplate": "GCS: E{e} V{v} M{m}"
          },
          {
            "id": "mental_state",
            "label": "Mental state",
            "type": "multiple_choice",
            "width": "half",
            "options": [
              "Alert",
              "Confused",
              "Drowsy",
              "Stupor"
            ],
            "allowComment": true,
            "commentSingleLine": true,
            "customReport": "mental_followcmd"
          },
          {
            "id": "follow_cmd",
            "label": "Follow command",
            "type": "checkbox",
            "width": "half",
            "options": [
              "1 step",
              "2 steps",
              "3 steps",
              "Not follow command"
            ],
            "combineAdjacent": true,
            "maxSelect": 2,
            "consecutiveOnly": true,
            "allowComment": true,
            "commentSingleLine": true,
            "commentLabel": "Other",
            "hideInReport": true
          },
          {
            "id": "orientation",
            "label": "Orientated to",
            "type": "checkbox",
            "width": "half",
            "options": [
              "Name",
              "Age",
              "Time",
              "Place",
              "Person"
            ],
            "invertedCheckbox": true,
            "unableToAssess": true,
            "customReport": "orientation_split"
          },
          {
            "id": "speech",
            "label": "Speech",
            "type": "checkbox",
            "width": "full",
            "options": [
              "Normal",
              "Expressive dysphasia",
              "Receptive dysphasia",
              "Dysarthria"
            ],
            "allowOther": true
          },
          {
            "id": "cog_status",
            "label": "Cognitive assessment",
            "type": "multiple_choice",
            "width": "full",
            "options": [
              "Performed",
              {
                "value": "Failed to assess due to",
                "detail": true,
                "detailPlaceholder": "reason (e.g. poor GCS)"
              },
              "Declined"
            ],
            "customReport": "cog_status_header"
          },
          {
            "id": "amt",
            "label": "Abbreviated Mental Test (AMT)",
            "type": "sub_score",
            "mode": "options",
            "totalMax": 10,
            "required": true,
            "removable": true,
            "width": "full",
            "hint": "Cut-off 6/10. Score below cut-off indicates further evaluation for possible cognitive impairment.",
            "items": [
              {
                "id": "age",
                "label": "Age",
                "options": [
                  0,
                  1
                ]
              },
              {
                "id": "time",
                "label": "Time",
                "options": [
                  0,
                  1
                ]
              },
              {
                "id": "addr",
                "label": "Address for recall",
                "options": [
                  0,
                  1
                ]
              },
              {
                "id": "year",
                "label": "Current year",
                "options": [
                  0,
                  1
                ]
              },
              {
                "id": "place",
                "label": "Place",
                "options": [
                  0,
                  1
                ]
              },
              {
                "id": "recog",
                "label": "Recognition of two persons",
                "options": [
                  0,
                  1
                ]
              },
              {
                "id": "dob",
                "label": "Date of birth",
                "options": [
                  0,
                  1
                ]
              },
              {
                "id": "festival",
                "label": "Date of mid-Autumn festival",
                "options": [
                  0,
                  1
                ]
              },
              {
                "id": "leader",
                "label": "Name of present Governor / Chinese leader",
                "options": [
                  0,
                  1
                ]
              },
              {
                "id": "count_back",
                "label": "Count from 20 to 1 backwards",
                "options": [
                  0,
                  1
                ]
              }
            ],
            "reportTemplate": "Abbreviated Mental Test (AMT): {answer} (Cut off scores: <6 indicated further evaluations for possibility of cognitive impairment)",
            "breakdownItemsPerLine": 7,
            "breakdownSep": "   ",
            "showIf": {
              "questionId": "cog_status",
              "equals": "Performed"
            }
          },
          {
            "id": "cdt",
            "label": "Clock Drawing Test (CDT)",
            "type": "rating",
            "min": 0,
            "max": 10,
            "removable": true,
            "width": "full",
            "hint": "Cut-off 4. Lower score indicates lower cognitive function.",
            "reportTemplate": "Clock Drawing Test (CDT): {answer} (Cut off score: 3/4; Lower score indicated higher cognitive function)",
            "showIf": {
              "questionId": "cog_status",
              "equals": "Performed"
            }
          },
          {
            "id": "moca",
            "label": "HK-Montreal Cognitive Assessment (MoCA)",
            "type": "sub_score",
            "mode": "max",
            "totalMax": 30,
            "required": true,
            "removable": true,
            "width": "full",
            "headerInputs": [
              {
                "id": "moca_age_cluster",
                "label": "Age",
                "type": "select",
                "required": true,
                "placeholder": "Select age",
                "options": [
                  "65-69",
                  "70-79",
                  "≥80"
                ]
              },
              {
                "id": "moca_education",
                "label": "Education",
                "type": "select",
                "required": true,
                "placeholder": "Select education"
              }
            ],
            "items": [
              {
                "id": "visuospatial",
                "label": "Visuospatial / Executive",
                "max": 5
              },
              {
                "id": "naming",
                "label": "Naming",
                "max": 3
              },
              {
                "id": "attention",
                "label": "Attention",
                "max": 6
              },
              {
                "id": "language",
                "label": "Language",
                "max": 3
              },
              {
                "id": "abstraction",
                "label": "Abstraction",
                "max": 2
              },
              {
                "id": "recall",
                "label": "Delayed Recall",
                "max": 5
              },
              {
                "id": "orientation",
                "label": "Orientation",
                "max": 6
              }
            ],
            "breakdownItemsPerLine": 5,
            "breakdownSep": "   ",
            "customReport": "moca_full",
            "showIf": {
              "questionId": "cog_status",
              "equals": "Performed"
            }
          },
          {
            "id": "moca_band",
            "label": "MoCA percentile",
            "type": "multiple_choice",
            "width": "full",
            "mergeUp": true,
            "hideInForm": true,
            "options": [
              ">16th percentile",
              "≤16th percentile",
              "≤7th percentile",
              "≤2nd percentile"
            ],
            "showIf": {
              "questionId": "cog_status",
              "equals": "Performed"
            },
            "hideInReport": true
          },
          {
            "id": "cog_impression",
            "label": "Impression",
            "type": "short_text",
            "width": "full",
            "showIf": {
              "questionId": "cog_status",
              "equals": "Performed"
            },
            "hideInReport": true
          }
        ],
        "reportTitle": "D. Mental Function"
      },
      {
        "title": "Physical Assessment",
        "suspendSummaryBefore": "vision",
        "questions": [
          {
            "id": "complaint",
            "label": "Major complaint / others",
            "type": "short_text",
            "width": "full"
          },
          {
            "id": "power",
            "label": "Power",
            "type": "composite",
            "layout": "grid-2x2",
            "width": "half",
            "rowHeaders": [
              "Upper",
              "Lower"
            ],
            "colHeaders": [
              "Right",
              "Left"
            ],
            "parts": [
              {
                "id": "rul",
                "placeholder": "5"
              },
              {
                "id": "lul",
                "placeholder": "5"
              },
              {
                "id": "rll",
                "placeholder": "5"
              },
              {
                "id": "lll",
                "placeholder": "5"
              }
            ],
            "reportTemplate": "Power:\n{rul} | {lul}\n{rll} | {lll}"
          },
          {
            "id": "tone",
            "label": "Tone",
            "type": "multiple_choice",
            "width": "half",
            "options": [
              "NAD"
            ],
            "allowOther": true,
            "keepOtherLabel": true,
            "otherPlaceholder": "describe (e.g. increased on left side)"
          },
          {
            "id": "coordination",
            "label": "Coordination",
            "type": "multiple_choice",
            "width": "half",
            "mergeUp": true,
            "options": [
              "NAD"
            ],
            "allowOther": true,
            "keepOtherLabel": true,
            "otherPlaceholder": "describe (e.g. dysmetria L UL)"
          },
          {
            "id": "fthue",
            "label": "Hand function — FTHUE",
            "type": "fthue_grade",
            "width": "full",
            "hint": "Functional Test for the Hemiplegic Upper Extremity (1–7 each side). Pick the highest level the patient can perform on each side.",
            "reportTemplate": "Hand function (FTHUE): Right: {r}/7  Left: {l}/7"
          },
          {
            "id": "balance_sit",
            "label": "Balance — Sitting",
            "type": "checkbox",
            "width": "half",
            "options": [
              "Good",
              "Fair",
              "Poor"
            ],
            "combineAdjacent": true,
            "maxSelect": 2,
            "consecutiveOnly": true,
            "customReport": "balance_combo",
            "allowSuspend": true
          },
          {
            "id": "balance_stand",
            "label": "Balance — Standing",
            "type": "checkbox",
            "width": "half",
            "mergeUp": true,
            "options": [
              "Good",
              "Fair",
              "Poor"
            ],
            "combineAdjacent": true,
            "maxSelect": 2,
            "consecutiveOnly": true,
            "hideInReport": true,
            "allowSuspend": true
          },
          {
            "id": "transfer_lie_sit",
            "label": "Transfer — Lie to sit",
            "type": "checkbox",
            "width": "half",
            "options": [
              "Independent",
              "Supervision",
              "Mild Assistance",
              "Moderate Assistance",
              "Maximal Assistance",
              "Dependent"
            ],
            "combineAdjacent": true,
            "maxSelect": 2,
            "consecutiveOnly": true,
            "customReport": "transfer_combo",
            "allowSuspend": true
          },
          {
            "id": "transfer_sit_stand",
            "label": "Transfer — Sit to stand",
            "type": "checkbox",
            "width": "half",
            "mergeUp": true,
            "options": [
              "Independent",
              "Supervision",
              "Mild Assistance",
              "Moderate Assistance",
              "Maximal Assistance",
              "Dependent"
            ],
            "combineAdjacent": true,
            "maxSelect": 2,
            "consecutiveOnly": true,
            "hideInReport": true,
            "allowSuspend": true
          },
          {
            "id": "ambulation",
            "label": "Ambulation",
            "type": "checkbox",
            "width": "half",
            "options": [
              "Independent",
              "Supervision",
              "Mild Assistance",
              "Moderate Assistance",
              "Maximal Assistance",
              "Dependent"
            ],
            "combineAdjacent": true,
            "maxSelect": 2,
            "consecutiveOnly": true,
            "customReport": "ambulation_combo",
            "allowSuspend": true
          },
          {
            "id": "ambulation_aid",
            "label": "Ambulation aid",
            "type": "multiple_choice",
            "width": "half",
            "mergeUp": true,
            "options": [
              "Stick",
              "Quadripod",
              "Frame",
              "Rollator"
            ],
            "allowOther": true,
            "otherPlaceholder": "specify",
            "hideInReport": true
          },
          {
            "id": "vision",
            "label": "Vision",
            "type": "multiple_choice",
            "width": "half",
            "options": [
              "NAD"
            ],
            "allowOther": true,
            "keepOtherLabel": true,
            "otherPlaceholder": "describe deficit"
          },
          {
            "id": "hearing",
            "label": "Hearing",
            "type": "multiple_choice",
            "width": "half",
            "mergeUp": true,
            "options": [
              "NAD",
              {
                "value": "Impaired",
                "subOptions": [
                  "Left",
                  "Right",
                  "Bilateral"
                ]
              },
              "Deaf"
            ]
          },
          {
            "id": "sensation",
            "label": "Sensation / Proprioception",
            "type": "multiple_choice",
            "width": "half",
            "options": [
              "NAD"
            ],
            "allowOther": true,
            "keepOtherLabel": true,
            "otherPlaceholder": "describe deficit"
          },
          {
            "id": "sensation_other",
            "label": "Other",
            "type": "long_text",
