            "allowOther": true,
            "keepOtherLabel": true,
            "otherPlaceholder": "describe"
          },
          {
            "id": "coordination",
            "label": "Coordination",
            "type": "multiple_choice",
            "width": "half",
            "mergeUp": true,
            "options": [
              "NAD"
            ],
            "allowOther": true,
            "keepOtherLabel": true,
            "otherPlaceholder": "describe"
          },
          {
            "id": "balance_sitting_static",
            "label": "Balance - Sitting static",
            "type": "checkbox",
            "width": "half",
            "options": [
              "Good",
              "Fair",
              "Poor"
            ],
            "combineAdjacent": true,
            "maxSelect": 2,
            "consecutiveOnly": true,
            "customReport": "essential_tremor_balance"
