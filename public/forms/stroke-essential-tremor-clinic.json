{
  "specialty": "Stroke",
  "title": "Essential Tremor Clinic",
  "description": "Stroke Essential Tremor clinic assessment.",
  "schema": {
    "sections": [
      {
        "title": "Social History and Home Environment",
        "hideReportTitle": true,
        "questions": [
          {
            "id": "attendance_mobility",
            "label": "Attendance and mobility",
            "type": "composite",
            "width": "full",
            "hideLabel": true,
            "customReport": "attendance_mobility",
            "parts": [
              {
                "id": "come_with",
                "label": "Come with",
                "placeholder": "family / carer",
                "wide": true,
                "showIf": {
                  "itemId": "come_alone",
                  "notEquals": true
                }
              },
              {
                "id": "come_alone",
                "label": "Come alone",
                "inputType": "checkbox",
                "suffix": ";"
              },
              {
                "id": "walk_with",
                "label": "Walk",
                "placeholder": "stick / rollator / frame",
                "wide": true,
                "showIf": {
                  "itemId": "on_wheelchair",
                  "notEquals": true
                }
              },
              {
                "id": "on_wheelchair",
                "label": "On wheelchair",
                "inputType": "checkbox"
              }
            ]
          },
          {
            "id": "review_period",
            "label": "Review period",
            "type": "multiple_choice",
            "width": "full",
            "reportTitle": " ",
            "reportHideTitle": true,
            "reportTemplate": "Review period: {answer}",
            "options": [
              "Baseline",
              "Post op",
              "Post op 1-month",
              "Post op 3-month",
              "Post op 6-month",
              "Post op 12-month"
            ]
          },
          {
            "id": "lives_with",
            "label": "Living arrangement",
            "type": "checkbox",
            "width": "full",
            "reportTitle": "Social History and Home Environment",
            "options": [
              {
                "value": "Live with",
                "detail": true,
                "detailPlaceholder": "family / carer"
              },
              "Live alone",
              "Day time alone",
              "OAHR"
            ],
            "allowOther": true,
            "allowComment": true,
            "commentLabel": "Main carer / details",
            "customReport": "social_lives_home"
          },
          {
            "id": "home_access",
            "label": "Home environment",
            "type": "multiple_choice",
            "width": "half",
            "options": [
              "Direct lift landing",
              {
                "value": "Non-direct lift landing",
                "detail": true,
                "detailPlaceholder": "FOS / floor"
              },
              {
                "value": "No lift",
                "detail": true,
                "detailPlaceholder": "FOS / floor"
              }
            ],
            "allowComment": true,
            "commentLabel": "Floor / stairs detail",
            "hideInReport": true
          },
          {
            "id": "bathing_setup",
            "label": "Bathing",
            "type": "checkbox",
            "width": "full",
            "options": [
              "Tub",
              "Shower",
              "Hot water system"
            ],
            "allowOther": true,
            "customReport": "bathing_combo"
          },
          {
            "id": "bath_method",
            "label": "Bath by",
            "type": "multiple_choice",
            "width": "full",
            "mergeUp": true,
            "options": [
              "Stand",
              "Squat",
              {
                "value": "Sit on",
                "subOptions": [
                  "Shower chair",
                  "Bath board",
                  "Shower stool"
                ],
                "subAllowOther": true
              },
              "Bedbath"
            ],
            "hideInReport": true
          },
          {
            "id": "social_service",
            "label": "Social support",
            "type": "checkbox",
            "width": "full",
            "options": [
              "Nil",
              "MOW",
              {
                "value": "Home Help Service",
                "subOptions": [
                  "Personal care",
                  "Household",
                  "Escort"
                ],
                "subAllowOther": true
              },
              "Day Care Centre",
              "Elderly Centre"
            ],
            "allowOther": true,
            "reportTemplate": "Social support: {answer}."
          },
          {
            "id": "financial",
            "label": "Financial",
            "type": "checkbox",
            "width": "full",
            "options": [
              "Family support / saving",
              "Comprehensive Social Security Assistance",
              "Disability Allowance",
              "Old Age Allowance",
              "Old Age Living Allowance"
            ],
            "allowOther": true,
            "reportTemplate": "Financial: {answer}."
          },
          {
            "id": "assistive_devices",
            "label": "Assistive device available",
            "type": "checkbox",
            "width": "full",
            "options": [
              "Nil",
              "Stick",
              "Quadripod",
              "Frame",
              "Rollator",
              "Wheelchair",
              "Commode",
              "Shower chair",
              "Bath board",
              "Handrail",
              "Safety alarm"
            ],
            "allowOther": true,
            "reportTemplate": "Assistive device available: {answer}."
          }
        ],
        "reportTitle": "Social History and Home Environment"
      },
      {
        "title": "Premorbid Function",
        "questions": [
          {
            "id": "badl",
            "label": "BADL",
            "type": "multiple_choice",
            "width": "full",
            "options": [
              "Independent",
              "Assistance",
              "Dependent"
            ],
            "allowComment": true,
            "commentLabel": "Detail",
            "commentSingleLine": true,
            "commentPlaceholder": "add detail",
            "customReport": "essential_tremor_premorbid"
          },
          {
            "id": "functional_mobility",
            "label": "Functional Mobility",
            "type": "multiple_choice",
            "width": "half",
            "options": [
              "Unaided",
              "Assisted",
              "Dependent"
            ],
            "hideInReport": true
          },
          {
            "id": "functional_mobility_aid",
            "label": "Aids",
            "type": "checkbox",
            "width": "half",
            "mergeUp": true,
            "options": [
              "Stick",
              "Quadripod",
              "Frame",
              "Rollator"
            ],
            "allowOther": true,
            "otherPlaceholder": "walking aid",
            "hideInReport": true
          },
          {
            "id": "outdoor_function",
            "label": "Outdoor",
            "type": "multiple_choice",
            "width": "full",
            "options": [
              "Independent",
              "Assistance",
              "Dependent"
            ],
            "allowComment": true,
            "commentLabel": "Detail",
            "commentSingleLine": true,
            "commentPlaceholder": "add detail",
            "hideInReport": true
          },
          {
            "id": "iadl",
            "label": "IADL",
            "type": "multiple_choice",
            "width": "full",
            "options": [
              "Independent",
              "Assistance",
              "Dependent"
            ],
            "allowComment": true,
            "commentLabel": "Detail",
            "commentSingleLine": true,
            "commentPlaceholder": "add detail",
            "hideInReport": true
          },
          {
            "id": "life_role",
            "label": "Life Role",
            "type": "multiple_choice",
            "width": "full",
            "options": [
              {
                "value": "Retired",
                "detail": true,
                "detailPlaceholder": "previous role",
                "detailJoiner": " "
              },
              {
                "value": "Unemployed",
                "detail": true,
                "detailPlaceholder": "details",
                "detailJoiner": " "
              },
              {
                "value": "Employed",
                "detail": true,
                "detailPlaceholder": "occupation",
                "detailJoiner": " "
              }
            ],
            "allowOther": true,
            "hideInReport": true
          },
          {
            "id": "dominant_hand",
            "label": "Dominant hand",
            "type": "multiple_choice",
            "width": "half",
            "options": [
              "Right",
              "Left"
            ],
            "hideInReport": true
          },
          {
            "id": "fall_history_recent",
            "label": "History of Fall in recent year",
            "type": "multiple_choice",
            "width": "half",
            "options": [
              "Nil",
              {
                "value": "Number of fall",
                "detail": true,
                "detailPlaceholder": "number"
              }
            ],
            "allowComment": true,
            "commentLabel": "Detail",
            "commentSingleLine": true,
            "commentPlaceholder": "fall detail",
            "hideInReport": true
          },
          {
            "id": "leisure",
            "label": "Leisure",
            "type": "long_text",
            "width": "full",
            "hideInReport": true
          }
        ],
        "reportTitle": "B. Premorbid Function"
      },
      {
        "title": "Medical History",
        "questions": [
          {
            "id": "tremor_onset",
            "label": "Tremor onset",
            "type": "long_text",
            "width": "full",
            "reportTemplate": "Tremor onset: {answer}"
          },
          {
            "id": "tremor_medication",
            "label": "Tremor medication",
            "type": "multiple_choice",
            "width": "full",
            "options": [
              "No",
              {
                "value": "Yes",
                "detail": true,
                "detailPlaceholder": "medication",
                "detailJoiner": ": "
              }
            ],
            "reportTemplate": "Tremor medication: {answer}"
          },
          {
            "id": "past_history",
            "label": "Past history",
            "type": "long_text",
            "width": "full",
            "reportTemplate": "Past history: {answer}"
          }
        ],
        "reportTitle": "C. Medical History"
      },
      {
        "title": "General Assessment",
        "questions": [
          {
            "type": "heading",
            "label": "Mental and Cognitive Function"
          },
          {
            "id": "mental_state",
            "label": "Mental state",
            "type": "multiple_choice",
            "width": "half",
            "options": [
              "Alert",
              "Dull",
              "Confused"
            ],
            "customReport": "essential_tremor_mental"
          },
          {
            "id": "follow_cmd_quality",
            "label": "Follow command",
            "type": "multiple_choice",
            "width": "half",
            "mergeUp": true,
            "options": [
              "Good",
              "Fair",
              "Poor"
            ],
            "hideInReport": true
          },
          {
            "id": "follow_cmd_steps",
            "label": "Step command",
            "type": "multiple_choice",
            "width": "full",
            "mergeUp": true,
            "options": [
              "1 step",
              "2 step",
              "3 step"
            ],
            "hideInReport": true
          },
          {
            "id": "cog_status",
            "label": "Cognition assessment",
            "type": "heading",
            "width": "full",
            "hideInReport": true
          },
          {
            "id": "moca",
            "label": "HK-Montreal Cognitive Assessment (MoCA)",
            "type": "sub_score",
            "mode": "max",
            "totalMax": 30,
            "width": "full",
            "breakdownItemsPerLine": 4,
            "breakdownSep": "   ",
            "customReport": "essential_tremor_moca",
            "headerInputs": [
              {
                "id": "moca_age_cluster",
                "label": "Age",
                "type": "select",
                "placeholder": "Select age",
                "options": [
                  "65-69",
                  "70-79",
                  "≥80"
                ]
              },
              {
                "id": "moca_education",
                "label": "Education",
                "type": "number",
                "inputType": "number",
                "placeholder": "Years",
                "min": 0,
                "step": 1
              }
            ],
            "items": [
              {
                "id": "executive_function",
                "label": "Executive Function",
                "max": 5
              },
              {
                "id": "naming",
                "label": "Naming",
                "max": 3
              },
              {
                "id": "attention",
                "label": "Attention",
                "max": 6
              },
              {
                "id": "language",
                "label": "Language",
                "max": 3
              },
              {
                "id": "abstraction",
                "label": "Abstraction",
                "max": 2
              },
              {
                "id": "delayed_recall",
                "label": "Delayed Recall",
                "max": 5
              },
              {
                "id": "orientation",
                "label": "Orientation",
                "max": 6
              }
            ]
          },
          {
            "id": "moca_band",
            "label": "MoCA percentile",
            "type": "multiple_choice",
            "width": "full",
            "mergeUp": true,
            "hideInForm": true,
            "options": [
              ">16th percentile",
              "<=16th percentile: DSM-5 minor NCD",
              "<=7th percentile: Petersen MCI",
              "<=2nd percentile: DSM-5 major NCD"
            ],
            "hideInReport": true
          },
          {
            "id": "major_complaint",
            "label": "Major complaint",
            "type": "short_text",
            "width": "full",
            "customReport": "essential_tremor_major_complaint"
          },
          {
            "type": "heading",
            "label": "Physical Assessment"
          },
          {
            "id": "power",
            "label": "Power",
            "type": "composite",
            "layout": "grid-2x2",
            "width": "half",
            "rowHeaders": [
              "Upper",
              "Lower"
            ],
            "colHeaders": [
              "Right",
              "Left"
            ],
            "parts": [
              {
                "id": "rul",
                "placeholder": "5"
              },
              {
                "id": "lul",
                "placeholder": "5"
              },
              {
                "id": "rll",
                "placeholder": "5"
              },
              {
                "id": "lll",
                "placeholder": "5"
              }
            ],
            "customReport": "essential_tremor_power"
          },
          {
            "id": "tone",
            "label": "Tone",
            "type": "multiple_choice",
            "width": "half",
            "options": [
              "NAD"
