            "type": "checkbox",
            "width": "half",
            "mergeUp": true,
            "options": [
              "Good",
              "Fair",
              "Poor"
            ],
            "combineAdjacent": true,
            "maxSelect": 2,
            "consecutiveOnly": true,
            "hideInReport": true
          },
          {
            "id": "transfer_level",
