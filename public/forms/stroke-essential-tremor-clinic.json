          {
            "id": "balance_sitting_dynamic",
            "label": "Balance - Sitting dynamic",
            "type": "checkbox",
            "width": "half",
            "mergeUp": true,
            "options": [
              "Good",
              "Fair",
              "Poor"
            ],
            "combineAdjacent": true,
            "maxSelect": 2,
            "consecutiveOnly": true,
            "hideInReport": true
          },
          {
            "id": "balance_standing_static",
